# OTILÌA — SMTP / contact form configuration.
# Copy this file to .env.local and fill in real values. Never commit secrets.
#
# Gmail note: with 2FA on you must use an "App Password" (16 chars) from
# https://myaccount.google.com/apppasswords — Gmail rejects regular passwords.

SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-studio-inbox@gmail.com
SMTP_PASS=your-app-password
STUDIO_INBOX=your-studio-inbox@gmail.com
